{
  "type": "origins:multiple",
  "name": "Charge Burst",
  "description": "To-do.",
  "cooldown": {
    "type": "origins:cooldown",
    "cooldown": 100,
    "hud_render": {
      "sprite_location": "*:textures/gui/community/leopardx/resource_bar_01.png",
      "bar_index": 3,
      "order": 4,
      "condition": {
        "type": "origins:and",
        "conditions": [
          {
            "type": "origins:xp_levels",
            "comparison": ">=",
            "compare_to": 20
          },
          {
            "type": "origins:dimension",
            "dimension": "minecraft:the_nether",
            "inverted": true
          }
        ]
      }
    }
  },
  "activation": {
    "type": "origins:active_self",
    "entity_action": {
      "type": "origins:if_else_list",
      "actions": [
        {
          "condition": {
            "type": "origins:xp_levels",
            "comparison": "<",
            "compare_to": 30
          },
          "action": {
            "type": "origins:and",
            "actions": [
              {
                "type": "origins:execute_command",
                "command": "title @s actionbar {\"text\":\"30 XP levels needed\",\"color\":\"red\"}"
              },
              {
                "type": "origins:execute_command",
                "command": "function rend:sounds/playsound_xp_warning"
              }
            ]
          }
        },
        {
          "condition": {
            "type": "origins:resource",
            "resource": "*:mana/soul_staff/staff_cooldown",
            "comparison": ">",
            "compare_to": 0
          },
          "action": {
            "type": "origins:execute_command",
            "command": "function rend:notification/notify_staff_on_cooldown"
          }
        },
        {
          "condition": {
            "type": "origins:resource",
            "resource": "*:*_cooldown",
            "comparison": ">",
            "compare_to": 0
          },
          "action": {
            "type": "origins:execute_command",
            "command": "function rend:notification/notify_spell_on_cooldown"
          }
        },
        {
          "condition": {
            "type": "origins:resource",
            "resource": "*:mana/mana_capacity",
            "comparison": "<",
            "compare_to": 5
          },
          "action": {
            "type": "origins:execute_command",
            "command": "function rend:notification/notify_spell_insufficient_mana"
          }
        },
        {
          "condition": {
            "type": "origins:constant",
            "value": true
          },
          "action": {
            "type": "origins:and",
            "actions": [
              {
                "type": "origins:trigger_cooldown",
                "power": "*:mana/soul_staff/staff_cooldown"
              },
              {
                "type": "origins:trigger_cooldown",
                "power": "*:*_cooldown"
              },
              {
                "type": "origins:swing_hand",
                "hand": "MAIN_HAND"
              },
              {
                "type": "origins:change_resource",
                "resource": "*:mana/mana_capacity",
                "change": -5
              },
              {
                "type": "origins:execute_command",
                "command": "scoreboard players set @s rend.air_burst.total_charges 15"
              },
              {
                "type": "origins:execute_command",
                "command": "scoreboard players operation @s rend.air_burst.charges_left = @s rend.air_burst.total_charges"
              },
              {
                "type": "origins:execute_command",
                "command": "resource operation @s rend:mana/soul_staff/charge_burst/air_burst_charges_left = @s rend.air_burst.charges_left"
              }
            ]
          }
        }
      ]
    },
    "key": "key.use",
    "condition": {
      "type": "origins:and",
      "conditions": [
        {
          "type": "origins:equipped_item",
          "equipment_slot": "mainhand",
          "item_condition": {
            "type": "origins:custom_data",
            "nbt": "{soul_staff: 1b}"
          }
        },
        {
          "type": "origins:equipped_item",
          "equipment_slot": "offhand",
          "item_condition": {
            "type": "origins:custom_data",
            "nbt": "{charge_burst_tome: 1b}"
          }
        },
        {
          "type": "origins:dimension",
          "dimension": "minecraft:the_nether",
          "inverted": true
        }
      ]
    }
  },
  "tooltip": {
    "type": "origins:tooltip",
    "texts": [
      {
        "text": "To-do",
