      },
      {
        "text": "§7XP Level: §330⟡"
      },
      {
        "text": "§7Cooldown: §r5s"
      }
    ],
    "item_condition": {
      "type": "origins:custom_data",
      "nbt": "{charge_burst_tome: 1b}"
    }
  },
  "badges": [
    {
      "type": "origins:tooltip",
      "sprite": "*:textures/gui/community/leopardx/badge/spell_tomes/cultivation.png",
      "text": "§eTome of Charge Burst§7               \nFound in all manner of §fto-do§7."
    }
  ]
