{
  "type": "origins:multiple",
  "do_vortex": {
    "type": "origins:action_over_time",
    "entity_action": {
      "type": "origins:and",
      "actions": [
        {
          "type": "origins:execute_command",
          "command": "execute positioned ~ ~-4 ~ run function rend:vortex/particles_all"
        },
        {
          "type": "origins:execute_command",
          "command": "tp @s ~ ~ ~ ~-12 ~"
        },
        {
          "type": "origins:play_sound",
          "sound": "minecraft:block.chorus_flower.grow",
          "category": "hostile",
          "pitch": 0,
          "volume": 2
        },
        {
          "type": "origins:area_of_effect",
          "radius": 8,
          "shape": "cube",
          "bientity_action": {
            "type": "origins:if_else",
            "condition": {
              "type": "origins:target_condition",
              "condition": {
                "type": "origins:entity_type",
                "entity_type": "minecraft:player"
              }
            },
            "if_action": {
              "type": "origins:and",
              "actions": [
                {
                  "type": "origins:add_velocity",
                  "x": 0.03,
                  "z": -0.2
                },
                {
                  "type": "origins:target_action",
                  "action": {
                    "type": "origins:apply_effect",
                    "effect": {
                      "id": "minecraft:levitation",
                      "duration": 20,
                      "amplifier": 1,
                      "show_particles": false,
                      "show_icon": false
                    }
                  }
                }
              ]
            },
            "else_action": {
              "type": "origins:add_velocity",
              "x": 0.1,
              "y": 0.15,
              "z": -0.35
            }
          },
          "bientity_condition": {
            "type": "origins:target_condition",
            "condition": {
              "type": "origins:in_tag",
              "tag": "*:inanimate",
              "inverted": true
            }
          }
        },
        {
          "type": "origins:change_resource",
          "resource": "*:*_timer",
          "change": -1
        }
      ]
    },
    "interval": 1,
    "condition": {
      "type": "origins:resource",
      "resource": "*:*_timer",
      "comparison": ">",
      "compare_to": 0
    }
  },
  "timer": {
    "type": "origins:resource",
    "min": 0,
    "max": 300,
    "start_value": 300,
    "min_action": {
      "type": "origins:execute_command",
      "command": "kill @s"
    }
  }
}
