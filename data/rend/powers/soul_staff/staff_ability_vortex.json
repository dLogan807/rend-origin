{
  "type": "origins:multiple",
  "name": "Create Vortex",
  "description": "Call forth a howling whirlwind.",
  "tome_vault": {
    "type": "origins:replace_loot_table",
    "replace": {
      "minecraft:chests/trial_chambers/reward": "rend:chests/vortex_tome/trial_vault"
    }
  },
  "tome_ominous_vault": {
    "type": "origins:replace_loot_table",
    "replace": {
      "minecraft:chests/trial_chambers/reward_ominous": "rend:chests/vortex_tome/trial_ominous_vault"
    }
  },
  "cooldown": {
    "type": "origins:cooldown",
    "cooldown": 1000,
    "hud_render": {
      "should_render": true,
      "sprite_location": "*:textures/gui/community/leopardx/resource_bar_01.png",
      "bar_index": 5,
      "order": 4,
      "condition": {
        "type": "origins:and",
        "conditions": [
          {
            "type": "origins:xp_levels",
            "comparison": ">=",
            "compare_to": 20
          },
          {
            "type": "origins:dimension",
            "dimension": "minecraft:the_nether",
            "inverted": true
          }
        ]
      }
    }
  },
  "activation": {
    "type": "origins:active_self",
    "entity_action": {
      "type": "origins:if_else_list",
      "actions": [
        {
          "condition": {
            "type": "origins:xp_levels",
            "comparison": "<",
            "compare_to": 35
          },
          "action": {
            "type": "origins:and",
            "actions": [
              {
                "type": "origins:execute_command",
                "command": "title @s actionbar {\"text\":\"35 XP levels needed\",\"color\":\"red\"}"
              },
              {
                "type": "origins:execute_command",
                "command": "function rend:sounds/playsound_xp_warning"
              }
            ]
          }
        },
        {
          "condition": {
            "type": "origins:resource",
            "resource": "*:soul_staff/soul_staff_cooldown",
            "comparison": ">",
            "compare_to": 0
          },
          "action": {
            "type": "origins:and",
            "actions": [
              {
                "type": "origins:execute_command",
                "command": "title @s actionbar {\"text\":\"Staff on cooldown\",\"color\":\"red\"}"
              },
              {
                "type": "origins:execute_command",
                "command": "function rend:sounds/playsound_unusable_warning"
              }
            ]
          }
        },
        {
          "condition": {
            "type": "origins:resource",
            "resource": "*:*_cooldown",
            "comparison": ">",
            "compare_to": 0
          },
          "action": {
            "type": "origins:execute_command",
            "command": "function rend:notification/notify_spell_on_cooldown"
          }
        },
        {
          "condition": {
            "type": "origins:resource",
            "resource": "*:mana_capacity",
            "comparison": "<",
            "compare_to": 20
          },
          "action": {
            "type": "origins:execute_command",
            "command": "function rend:notification/notify_spell_insufficient_mana"
          }
        },
        {
          "condition": {
            "type": "origins:constant",
            "value": true
          },
          "action": {
            "type": "origins:raycast",
            "distance": 70,
            "entity": false,
            "shape_type": "collider",
            "fluid_handling": "source_only",
            "hit_action": {
              "type": "origins:and",
              "actions": [
                {
                  "type": "origins:trigger_cooldown",
                  "power": "*:soul_staff/soul_staff_cooldown"
                },
                {
                  "type": "origins:trigger_cooldown",
                  "power": "*:*_cooldown"
                },
                {
                  "type": "origins:swing_hand",
                  "hand": "MAIN_HAND"
                },
                {
                  "type": "origins:change_resource",
                  "resource": "*:mana_capacity",
                  "change": -20
                }
              ]
            },
            "block_action": {
              "type": "origins:offset",
              "y": 5,
              "action": {
                "type": "origins:spawn_entity",
                "entity_type": "minecraft:bat",
                "tag": "{Invulnerable:1b,NoGravity:1b,Silent:1b}",
                "entity_action": {
                  "type": "origins:and",
                  "actions": [
                    {
                      "type": "origins:apply_effect",
                      "effect": {
                        "id": "minecraft:invisibility",
                        "show_particles": false,
                        "duration": -1
                      }
                    },
                    {
                      "type": "origins:spawn_entity",
                      "entity_type": "minecraft:armor_stand",
                      "tag": "{Invulnerable:1b,NoGravity:1b,Invisible:1b}",
                      "entity_action": {
                        "type": "origins:grant_power",
                        "power": "*:soul_staff/vortex/vortex",
                        "source": "*:soul_staff/vortex/base"
                      },
                      "bientity_action": {
                        "type": "origins:invert",
                        "action": {
                          "type": "origins:mount"
                        }
                      }
                    }
                  ]
                }
              }
            },
            "command_along_ray": "particle minecraft:cloud",
            "command_step": 1,
            "command_along_ray_only_on_hit": false
          }
        }
      ]
    },
    "key": "key.use",
    "condition": {
      "type": "origins:and",
      "conditions": [
        {
          "type": "origins:equipped_item",
          "equipment_slot": "mainhand",
          "item_condition": {
            "type": "origins:custom_data",
            "nbt": "{soul_staff: 1b}"
          }
        },
        {
          "type": "origins:equipped_item",
          "equipment_slot": "offhand",
          "item_condition": {
            "type": "origins:custom_data",
            "nbt": "{vortex_tome: 1b}"
          }
        },
        {
          "type": "origins:dimension",
          "dimension": "minecraft:the_nether",
          "inverted": true
        }
      ]
    }
  },
  "tooltip": {
    "type": "origins:tooltip",
    "texts": [
      {
        "text": "Accelerate air into",
        "type": "text",
        "italic": true,
        "color": "gray"
      },
      {
        "text": "inescapable gusts.",
        "type": "text",
        "italic": true,
        "color": "gray"
      },
      { "text": "" },
      {
        "text": "§7Mana Cost: §b-20%"
      },
      {
        "text": "§7XP Level: §335⟡"
      },
      {
        "text": "§7Cooldown: §r50s"
      }
    ],
    "item_condition": {
      "type": "origins:custom_data",
      "nbt": "{vortex_tome: 1b}"
    }
  },
  "badges": [
    {
      "type": "origins:tooltip",
      "sprite": "*:textures/gui/community/leopardx/badge/spell_tomes/vortex.png",
      "text": "§eTome of Create Vortex         \n§7Found in §fTrail Chamber vaults§7."
    }
  ]
}
