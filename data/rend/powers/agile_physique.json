{
  "type": "origins:multiple",
  "name": "Agile Physique",
  "description": "You have a light and nimble body but aren't particularly strong.",
  "set_scaled_modifiers": {
    "type": "origins:action_over_time",
    "interval": 40,
    "entity_action": {
      "type": "origins:and",
      "actions": [
        {
          "type": "origins:execute_command",
          "command": "function rend:agile_physique/calc_and_set_armour_modifiers"
        },
        {
          "type": "origins:execute_command",
          "command": "function rend:agile_physique/calc_and_set_speed_modifiers"
        }
      ]
    }
  },
  "reduce_fall_damage": {
    "type": "origins:modify_damage_taken",
    "modifier": {
      "id": "*:*",
      "operation": "multiply_base_multiplicative",
      "amount": -0.33
    },
    "damage_condition": {
      "type": "origins:type",
      "damage_type": "minecraft:fall"
    },
    "condition": {
      "type": "origins:sneaking"
    }
  },
  "negate_fall_damage": {
    "type": "origins:invulnerability",
    "damage_condition": {
      "type": "origins:type",
      "damage_type": "minecraft:fall"
    },
    "condition": {
      "type": "origins:and",
      "conditions": [
        {
          "type": "origins:fall_distance",
          "comparison": "<=",
          "compare_to": 5
        },
        {
          "type": "origins:sneaking"
        }
      ]
    }
  },
  "increase_damage_taken": {
    "type": "origins:modify_damage_taken",
    "modifier": {
      "operation": "add_base_late",
      "amount": 1
    }
  },
  "increased_damage_from_behind": {
    "type": "origins:modify_damage_taken",
    "self_action": {
      "type": "origins:and",
      "actions": [
        {
          "type": "origins:execute_command",
          "command": "particle minecraft:crit ~ ~1 ~ .1 .1 .1 0.20 15"
        },
        {
          "type": "origins:play_sound",
          "sound": "minecraft:entity.player.attack.crit",
          "category": "players",
          "pitch": 2,
          "volume": 0.7
        }
      ]
    },
    "bientity_condition": {
      "type": "origins:and",
      "conditions": [
        {
          "type": "origins:actor_condition",
          "condition": {
            "type": "origins:exists"
          }
        },
        {
          "type": "origins:relative_rotation",
          "axes": ["x", "z"],
          "actor_rotation": "body",
          "target_rotation": "body",
          "comparison": ">=",
          "compare_to": 0.9
        }
      ]
    },
    "modifier": {
      "id": "*:agile_physique_increased_behind_damage",
      "amount": 0.5,
      "operation": "multiply_base_additive"
    },
    "damage_condition": {
      "type": "origins:amount",
      "comparison": ">",
      "compare_to": 0
    }
  },
  "axe_insuitability": {
    "type": "origins:tooltip",
    "hidden": true,
    "texts": [
      {
        "text": "Clunky weapon (§cAgile Physique§7)",
        "color": "gray"
      }
    ],
    "item_condition": {
      "type": "origins:ingredient",
      "ingredient": {
        "tag": "*:axes"
      }
    }
  },
  "badges": [
    {
      "type": "origins:tooltip",
      "sprite": "*:textures/gui/community/leopardx/badge/xp_orb.png",
      "text": [
        "§8§oYour strength accumulates with your experience.",
        "\n\n§7Up to §330⟡ levels§7, you struggle to wear armour, which §cdecreases§7 your movement speed.",
        "\n§7Following this, your attack and movement speed §eprogressively increase§7."
      ]
    },
    {
      "type": "origins:tooltip",
      "sprite": "origins:textures/gui/community/silent/badge/shapes/shape_heart.png",
      "text": [
        "§8§oNimble as you may be, your body is frail.",
        "\n\n§7Your maximum health is §c9❤§7.",
        "\n\n§7You take §c0.5❤§7 more damage from §oeverything§r§7 and damage is increased by §c50%§7 when §eattacked from behind§r."
      ]
    },
    {
      "type": "origins:tooltip",
      "sprite": "*:textures/gui/community/leopardx/badge/feather.png",
      "text": [
        "§8§oYou're adept at landing gracefully on your feet.",
        "\n\n§7Hold [",
        { "keybind": "key.sneak" },
        "§7] to §anegate§7 short falls and reduce fall damage by §a33%§7."
      ]
    },
    {
      "type": "origins:tooltip",
      "sprite": "origins:textures/gui/community/silent/badge/icons/sword.png",
      "text": [
        "§8§oYou simply aren't suited to wield axes.",
        "\n\n§7Axes are always of §creduced effectiveness§7, having §c-50%§7 attack speed and dealing §c5 ❤§7 less damage."
      ]
    },
    {
      "type": "origins:tooltip",
      "sprite": "*:textures/gui/community/leopardx/badge/cursed_prison.png",
      "text": [
        "§4§lCursed Prison ⛓",
        "\n\n§8§oYou feel your confidence §c§oshatter§8§o as you move through this dimension of failed conquest.",
        "\n\n§cNo§7 attack or movement speed buffs in the §4Nether§7."
      ]
    }
  ]
}
